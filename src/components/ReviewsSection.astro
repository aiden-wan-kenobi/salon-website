---
/**
 * ReviewsSection component
 * Single Responsibility: Display customer reviews in a 3-card grid
 */
import { reviews } from '../data/reviews';
import { BUSINESS_INFO } from '../config/constants';
const displayReviews = reviews.slice(0, 3);
---

<section class="reviews">
  <div class="reviews-inner">
    <div class="reviews-header">
      <p class="section-eyebrow">Client Love</p>
      <h2 class="section-title">What our clients are <em>saying.</em></h2>
      <p class="reviews-subtitle">
        {BUSINESS_INFO.aggregateRating.ratingValue} stars across {BUSINESS_INFO.aggregateRating.reviewCount} Google reviews
      </p>
      <div class="review-summary" aria-label="Google review summary">
        <div>
          <strong>{BUSINESS_INFO.aggregateRating.ratingValue}★</strong>
          <span>Google rating</span>
        </div>
        <div>
          <strong>{BUSINESS_INFO.aggregateRating.reviewCount}</strong>
          <span>Google reviews</span>
        </div>
        <div>
          <strong>47</strong>
          <span>five-star reviews</span>
        </div>
      </div>
      <div class="divider"><span class="divider-icon">✦</span></div>
    </div>

    <div class="reviews-grid">
      {displayReviews.map((review) => (
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <blockquote class="review-text">"{review.text}"</blockquote>
          <div class="review-author">{review.name}</div>
          {review.services && (
            <div class="review-service">{review.services[0]}{review.stylist ? ` · ${review.stylist}` : ''}</div>
          )}
          {review.source && <div class="review-source">{review.source} review</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    padding: 6rem 2rem;
    background: var(--cream);
  }

  .reviews-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .reviews-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--deep);
    margin: 0 0 0.5rem;
  }

  .section-title em {
    font-style: italic;
    color: var(--rose);
  }

  .reviews-subtitle {
    font-family: 'Jost', sans-serif;
    font-size: 0.88rem;
    color: var(--warm-gray);
    margin: 0 0 2rem;
    font-weight: 300;
  }

  .review-summary {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 0 auto 2rem;
  }

  .review-summary div {
    min-width: 130px;
    border: 1px solid var(--blush);
    background: rgba(255, 255, 255, 0.55);
    padding: 0.9rem 1rem;
  }

  .review-summary strong,
  .review-summary span {
    display: block;
    font-family: 'Jost', sans-serif;
  }

  .review-summary strong {
    color: var(--deep);
    font-size: 1rem;
    font-weight: 500;
  }

  .review-summary span {
    color: var(--warm-gray);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
  }

  .divider::before,
  .divider::after {
    content: '';
    width: 60px;
    height: 1px;
    background: var(--blush);
  }

  .divider-icon {
    color: var(--rose);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .review-card {
    background: #fff;
    padding: 2rem 2rem 1.75rem;
    border-top: 2px solid var(--blush);
    box-shadow: 0 4px 20px rgba(61, 43, 35, 0.07);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .review-card:hover {
    border-color: var(--rose);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(61, 43, 35, 0.12);
  }

  .review-stars {
    color: var(--gold);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .review-text {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 300;
    color: var(--deep);
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .review-author {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--warm-gray);
  }

  .review-service {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    color: var(--rose);
    margin-top: 0.25rem;
  }

  .review-source {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-top: 0.6rem;
  }

  @media (max-width: 900px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .reviews {
      padding: 4rem 1.25rem;
    }
  }
</style>
