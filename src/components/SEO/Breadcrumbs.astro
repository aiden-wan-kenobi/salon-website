---
/**
 * Reusable Breadcrumbs component for SEO
 * Single Responsibility: Generate breadcrumb structured data
 */
import { generateBreadcrumbSchema } from "../../utils/structuredData";
import type { BreadcrumbItem } from "../../utils/structuredData";
import { getCanonicalUrl } from "../../utils/seo";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const breadcrumbData = generateBreadcrumbSchema(
  items.map((item) => ({
    ...item,
    url: getCanonicalUrl(new URL(item.url, Astro.site).pathname),
  }))
);
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbData)}
></script>
